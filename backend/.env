# SECURITY WARNING: keep the secret key used in production secret!
SECRET_KEY=django-insecure-local-development-key-only-1234!!

# SECURITY WARNING: For local laptop development, this stays True
DEBUG=True

# DOMAINS: Allow everything locally
ALLOWED_HOSTS=*

# CORS: Allow local React ports to connect
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

# Razorpay (Optional)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Telegram Alerts (Optional)
TELEGRAM_BOT_TOKEN=
